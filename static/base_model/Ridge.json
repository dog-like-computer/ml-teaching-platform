{
    "model": "Ridge",
    "alpha": {
        "default": 1.0,
        "range": [0.0, 10.0],
        "type": "float"
    },
    "fit_intercept": {
        "default": true,
        "options": [true, false],
        "type": "bool"
    },
    "solver": {
        "default": "cholesky",
        "options": ["cholesky", "sgd"],
        "type": "str"
    },
    "max_iter": {
        "default": 1000,
        "range": [100, 10000],
        "type": "int"
    },
    "tol": {
        "default": 0.001,
        "range": [1e-6, 1e-2],
        "type": "float"
    },
    "learning_rate": {
        "default": 0.01,
        "range": [1e-5, 1.0],
        "type": "float"
    },
    "copy_X": {
        "default": true,
        "options": [true, false],
        "type": "bool"
    },
    "random_state": {
        "default": null,
        "type": "int or null"
    }
}